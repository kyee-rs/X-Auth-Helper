{
    "manifest_version": 2,
    "name": "X Auth Helper",
    "version": "1.0",
    "description": "Retrieves X key for logged in user. Requires cookies permission.",
    "permissions": ["cookies", "*://x.com/*"],
    "incognito": "spanning",
    "icons": {
        "16": "icons/icon16.png",
        "32": "icons/icon32.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "background": {
        "scripts": ["background.js"],
        "persistent": false
    },
    "browser_action": {
        "default_popup": "pages/popup.html"
    }
}
